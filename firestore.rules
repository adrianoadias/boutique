rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default open read/write rules for registrations and backups to guarantee instant, unblocked submissions from any browser/device!
    match /registrations/{regId} {
      allow read, write: if true;
    }
    match /backups/{backupId} {
      allow read, write: if true;
    }
  }
}
